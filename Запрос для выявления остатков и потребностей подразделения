ВЫБРАТЬ
	ЗаявкиСотрудниковОстатки.Канцтовар КАК Канцтовар,
	ЗаявкиСотрудниковОстатки.ЗаявкаСотрудника КАК ЗаявкаСотрудника,
	ЗаявкиСотрудниковОстатки.КоличествоОстаток - ЕСТЬNULL(ПотребностиПодразделенийОстатки.КоличествоОстаток, 0) КАК КоличествоПоЗаявкам,
	ПотребностиПодразделенийОстатки.КоличествоОстаток КАК КоличествоЗафиксированнойПотребности
ПОМЕСТИТЬ ВТ_СкорректированныеЗаявки
ИЗ
	РегистрНакопления.ЗаявкиСотрудников.Остатки(, Сотрудник.Подразделение = &Подразделение) КАК ЗаявкиСотрудниковОстатки
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ПотребностиПодразделений.Остатки(, Подразделение = &Подразделение) КАК ПотребностиПодразделенийОстатки
		ПО (ЗаявкиСотрудниковОстатки.Канцтовар = ПотребностиПодразделенийОстатки.Канцтовар)
			И (ЗаявкиСотрудниковОстатки.ЗаявкаСотрудника = ПотребностиПодразделенийОстатки.ЗаявкаСотрудника)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	МинимальныеОстатки.Канцтовар КАК Канцтовар,
	NULL КАК Заявка,
	МинимальныеОстатки.Количество КАК МинимальныйОстаток,
	0 КАК КоличествоПоЗаявкам,
	0 КАК ОстатокПоПодразделению,
	0 КАК ЗафиксированнаяПотребность
ПОМЕСТИТЬ ВТ_ИсходныеДанные
ИЗ
	РегистрСведений.МинимальныеОстатки КАК МинимальныеОстатки
ГДЕ
	МинимальныеОстатки.Подразделение = &Подразделение

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ВТ_СкорректированныеЗаявки.Канцтовар,
	ВТ_СкорректированныеЗаявки.ЗаявкаСотрудника,
	0,
	ВТ_СкорректированныеЗаявки.КоличествоПоЗаявкам,
	0,
	0
ИЗ
	ВТ_СкорректированныеЗаявки КАК ВТ_СкорректированныеЗаявки

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ОстаткиПодразделенийОстатки.Канцтовар,
	NULL,
	0,
	0,
	ОстаткиПодразделенийОстатки.КоличествоОстаток,
	0
ИЗ
	РегистрНакопления.ОстаткиПодразделений.Остатки(, Подразделение = &Подразделение) КАК ОстаткиПодразделенийОстатки

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ПотребностиПодразделенийОстатки.Канцтовар,
	ПотребностиПодразделенийОстатки.ЗаявкаСотрудника,
	0,
	0,
	0,
	ВЫБОР
		КОГДА ПотребностиПодразделенийОстатки.КоличествоОстаток < 0
			ТОГДА 0
		ИНАЧЕ ПотребностиПодразделенийОстатки.КоличествоОстаток
	КОНЕЦ
ИЗ
	РегистрНакопления.ПотребностиПодразделений.Остатки(
			,
			Подразделение = &Подразделение
				И ЗаявкаСотрудника = ЗНАЧЕНИЕ(Документ.ЗаявкаСотрудника.ПустаяСсылка)) КАК ПотребностиПодразделенийОстатки
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_ИсходныеДанные.Канцтовар КАК Канцтовар,
	СУММА(ВТ_ИсходныеДанные.МинимальныйОстаток) КАК МинимальныйОстаток,
	СУММА(ВТ_ИсходныеДанные.ОстатокПоПодразделению) КАК ОстатокПоПодразделению,
	СУММА(ВТ_ИсходныеДанные.КоличествоПоЗаявкам) КАК КоличествоПоЗаявкам,
	СУММА(ВТ_ИсходныеДанные.ЗафиксированнаяПотребность) КАК ЗафиксированнаяПотребность,
	СУММА(ВТ_ИсходныеДанные.МинимальныйОстаток) + СУММА(ВТ_ИсходныеДанные.КоличествоПоЗаявкам) - СУММА(ВТ_ИсходныеДанные.ОстатокПоПодразделению) - СУММА(ВТ_ИсходныеДанные.ЗафиксированнаяПотребность) КАК Потребность
ПОМЕСТИТЬ ВТ_Сводная
ИЗ
	ВТ_ИсходныеДанные КАК ВТ_ИсходныеДанные

СГРУППИРОВАТЬ ПО
	ВТ_ИсходныеДанные.Канцтовар

ИМЕЮЩИЕ
	СУММА(ВТ_ИсходныеДанные.МинимальныйОстаток) + СУММА(ВТ_ИсходныеДанные.КоличествоПоЗаявкам) - СУММА(ВТ_ИсходныеДанные.ОстатокПоПодразделению) - СУММА(ВТ_ИсходныеДанные.ЗафиксированнаяПотребность) > 0
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_Сводная.Канцтовар КАК Канцтовар,
	ВТ_Сводная.МинимальныйОстаток КАК МинимальныйОстаток,
	ВТ_Сводная.ОстатокПоПодразделению КАК ОстатокПоПодразделению,
	ВТ_Сводная.КоличествоПоЗаявкам КАК КоличествоПоЗаявкам,
	ВТ_Сводная.ЗафиксированнаяПотребность КАК ЗафиксированнаяПотребность,
	ВТ_Сводная.Потребность КАК Потребность,
	ВТ_СкорректированныеЗаявки.ЗаявкаСотрудника КАК ЗаявкаСотрудника,
	ВТ_СкорректированныеЗаявки.КоличествоПоЗаявкам КАК КоличествоПоЗаявкамДетально
ИЗ
	ВТ_Сводная КАК ВТ_Сводная
		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СкорректированныеЗаявки КАК ВТ_СкорректированныеЗаявки
		ПО (ВТ_Сводная.Канцтовар = ВТ_СкорректированныеЗаявки.Канцтовар)
ИТОГИ
	МАКСИМУМ(МинимальныйОстаток),
	МАКСИМУМ(ОстатокПоПодразделению),
	МАКСИМУМ(КоличествоПоЗаявкам),
	МАКСИМУМ(ЗафиксированнаяПотребность),
	МАКСИМУМ(Потребность),
	СУММА(КоличествоПоЗаявкамДетально)
ПО
	Канцтовар
