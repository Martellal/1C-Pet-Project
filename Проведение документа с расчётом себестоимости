
Процедура ОбработкаПроведения(Отказ, Режим)

	Движения.ОстаткиНаСкладах.Записывать = Истина;
	Для Каждого ТекСтрокаКанцтовары Из Канцтовары Цикл
		Движение = Движения.ОстаткиНаСкладах.Добавить();
		Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
		Движение.Период = Дата;
		Движение.Склад = Склад;
		Движение.Канцтовар = ТекСтрокаКанцтовары.Канцтовар;
		Движение.Количество = ТекСтрокаКанцтовары.Количество;
		Движение.Комментарий = Комментарий;
	КонецЦикла;

	Движения.ПотребностиПодразделений.Записывать = Истина;
	Для Каждого ТекСтрокаКанцтовары Из Канцтовары Цикл
		Движение = Движения.ПотребностиПодразделений.Добавить();
		Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
		Движение.Период = Дата;
		Движение.Подразделение = ТекСтрокаКанцтовары.Подразделение;
		Движение.Канцтовар = ТекСтрокаКанцтовары.Канцтовар;
		Движение.ЗаявкаСотрудника = ТекСтрокаКанцтовары.ЗаявкаСотрудника;
		Движение.Количество = ТекСтрокаКанцтовары.Количество;
		Движение.Комментарий = Комментарий;
	КонецЦикла;

	Движения.Себестоимость.Записывать = Истина;
	Движения.Себестоимость.Очистить();
	Движения.Себестоимость.Записать();
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ВыполнениеПотребностиПодразделенияКанцтовары.Канцтовар КАК Канцтовар,
	|	СУММА(ВыполнениеПотребностиПодразделенияКанцтовары.Количество) КАК Количество
	|ПОМЕСТИТЬ ТаблицаДокумента
	|ИЗ
	|	Документ.ВыполнениеПотребностиПодразделения.Канцтовары КАК ВыполнениеПотребностиПодразделенияКанцтовары
	|ГДЕ
	|	ВыполнениеПотребностиПодразделенияКанцтовары.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ВыполнениеПотребностиПодразделенияКанцтовары.Канцтовар
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаДокумента.Канцтовар КАК Канцтовар,
	|	ТаблицаДокумента.Количество КАК Количество,
	|	ТаблицаДокумента.Количество - ЕСТЬNULL(СебестоимостьОстатки.КоличествоОстаток, 0) КАК Разница,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СебестоимостьОстатки.КоличествоОстаток, 0) = 0
	|			ТОГДА 0
	|		ИНАЧЕ СебестоимостьОстатки.СуммаОстаток / СебестоимостьОстатки.КоличествоОстаток * ТаблицаДокумента.Количество
	|	КОНЕЦ КАК Себестоимость,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.Количество > ЕСТЬNULL(СебестоимостьОстатки.КоличествоОстаток, 0)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ТовараНедостаточно
	|ИЗ
	|	ТаблицаДокумента КАК ТаблицаДокумента
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Себестоимость.Остатки(&Граница, ) КАК СебестоимостьОстатки
	|		ПО ТаблицаДокумента.Канцтовар = СебестоимостьОстатки.Канцтовар");
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("Граница", МоментВремени());
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.ТовараНедостаточно Тогда
			Отказ = Истина;
			Сообщить("По канцтовару " + Выборка.Канцтовар + "Недостаточно остатка по регистру себестоимость! Не хватает" + Выборка.Разница + "шт");
		КонецЕсли;
		Движение = Движения.Себестоимость.Добавить();
		Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
		Движение.Период = Дата;
		Движение.Канцтовар = Выборка.Канцтовар;
		Движение.Количество = Выборка.Количество;
		Движение.Сумма = Выборка.Себестоимость;
		Движение.Комментарий = Комментарий;
		КонецЦикла;

		ТЗСебестоимости = Движения.Себестоимость.Выгрузить();
		КанцтоварыСвернуто = Канцтовары.Выгрузить();
		КанцтоварыСвернуто.Свернуть("Канцтовар,Подразделение", "Количество");
		Движения.ОстаткиПодразделений.Записывать = Истина;
		Для Каждого СтрокаСебестоимости Из ТЗСебестоимости Цикл
			СуммаРаспределить = СтрокаСебестоимости.Сумма;
			НС = КанцтоварыСвернуто.НайтиСтроки(Новый Структура("Канцтовар", СтрокаСебестоимости.Канцтовар));
			Для Каждого НайденнаяСтрока Из НС Цикл
				Если СуммаРаспределить<= 0 Тогда
					Продолжить;
				КонецЕсли;
				Движение = Движения.ОстаткиПодразделений.Добавить();
				Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
				Движение.Период = Дата;
				Движение.Подразделение = НайденнаяСтрока.Подразделение;
				Движение.Канцтовар = НайденнаяСтрока.Канцтовар;
				Движение.Количество = НайденнаяСтрока.Количество;
				Движение.Сумма = СтрокаСебестоимости.Сумма/СтрокаСебестоимости.Количество*НайденнаяСтрока.Количество;
				Движение.Комментарий = Комментарий;
				СуммаРаспределить = СуммаРаспределить - Движение.Сумма;
				КонецЦикла;
			КонецЦикла;	
	
	Движения.Записать();
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ПотребностиПодразделенийОстатки.Подразделение,
	|	ПотребностиПодразделенийОстатки.Канцтовар,
	|	ПотребностиПодразделенийОстатки.ЗаявкаСотрудника,
	|	-ПотребностиПодразделенийОстатки.КоличествоОстаток КАК Превышение
	|ИЗ
	|	РегистрНакопления.ПотребностиПодразделений.Остатки(&МоментВремени, Канцтовар В (&СписокКанцтоваров)) КАК ПотребностиПодразделенийОстатки
	|ГДЕ
	|	ПотребностиПодразделенийОстатки.КоличествоОстаток < 0";
	Запрос.УстановитьПараметр("МоментВремени", Новый Граница(МоментВремени(), ВидГраницы.Включая));
	Запрос.УстановитьПараметр("СписокКанцтоваров", Канцтовары.ВыгрузитьКолонку("Канцтовар"));
	Рез = Запрос.Выполнить();
	Если Не Рез.Пустой() Тогда
		Отказ = Истина;
		Выборка = Рез.Выбрать();
		Пока Выборка.Следующий() Цикл
			Сообщить("Превышено количество потребности по подразделению: " + Выборка.Подразделение + "; канцтовар " + Выборка.Канцтовар + ". Превышение" + Выборка.Превышение + "шт");
		КонецЦикла;
	КонецЕсли;
	Запрос.Текст = "ВЫБРАТЬ
	|	ОстаткиНаСкладахОстатки.Канцтовар,
	|	-ОстаткиНаСкладахОстатки.КоличествоОстаток КАК Превышение
	|ИЗ
	|	РегистрНакопления.ОстаткиНаСкладах.Остатки(
	|			&МоментВремени,
	|			Канцтовар В (&СписокКанцтоваров)
	|				И Склад = &Склад) КАК ОстаткиНаСкладахОстатки
	|ГДЕ
	|	ОстаткиНаСкладахОстатки.КоличествоОстаток < 0";
	Запрос.УстановитьПараметр("Склад", Склад);
	Рез = Запрос.Выполнить();
	Если Не Рез.Пустой() Тогда
		Отказ = Истина;                                                   
		Выборка = Рез.Выбрать();
		Пока Выборка.Следующий() Цикл
			Сообщить("Превышен остаток по складу: " + Склад + "; канцтовар " + Выборка.Канцтовар + ". Превышение" + Выборка.Превышение + "шт");
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)

	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПотребностьПодразделения") Тогда

		Комментарий = ДанныеЗаполнения.Комментарий;
		Для Каждого ТекСтрокаКанцтовары Из ДанныеЗаполнения.Канцтовары Цикл
			НоваяСтрока = Канцтовары.Добавить();
			НоваяСтрока.ЗаявкаСотрудника = ТекСтрокаКанцтовары.ЗаявкаСотрудника;
			НоваяСтрока.Канцтовар = ТекСтрокаКанцтовары.Канцтовар;
			НоваяСтрока.Количество = ТекСтрокаКанцтовары.Количество;
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры
