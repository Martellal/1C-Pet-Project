
Процедура ОбработкаПроведения(Отказ, Режим)	
	
	Движения.ЗаявкиСотрудников.Записывать = Истина;
	Для Каждого ТекСтрокаЗаявки Из Заявки Цикл
		Движение = Движения.ЗаявкиСотрудников.Добавить();
		Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
		Движение.Период = Дата;
		Движение.Сотрудник = ТекСтрокаЗаявки.Сотрудник;
		Движение.Канцтовар = ТекСтрокаЗаявки.Канцтовар;
		Движение.ЗаявкаСотрудника = ТекСтрокаЗаявки.ЗаявкаСотрудника;
		Движение.Количество = ТекСтрокаЗаявки.Количество;
		Движение.Комментарий = Комментарий;
	КонецЦикла;	
	
	Движения.ОстаткиПодразделений.Записывать = Истина;
	Движения.ОстаткиПодразделений.Очистить();
	Движения.ОстаткиПодразделений.Записать();
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ИсполнениеЗаявкиСотрудникаЗаявки.Канцтовар КАК Канцтовар,
	|	СУММА(ИсполнениеЗаявкиСотрудникаЗаявки.Количество) КАК Количество,
	|	ИсполнениеЗаявкиСотрудникаЗаявки.Подразделение
	|ПОМЕСТИТЬ ТаблицаДокумента
	|ИЗ
	|	Документ.ИсполнениеЗаявкиСотрудника.Заявки КАК ИсполнениеЗаявкиСотрудникаЗаявки
	|ГДЕ
	|	ИсполнениеЗаявкиСотрудникаЗаявки.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ИсполнениеЗаявкиСотрудникаЗаявки.Канцтовар,
	|	ИсполнениеЗаявкиСотрудникаЗаявки.Подразделение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаДокумента.Канцтовар КАК Канцтовар,
	|	ТаблицаДокумента.Количество КАК Количество,
	|	ТаблицаДокумента.Подразделение,
	|	ТаблицаДокумента.Количество - ЕСТЬNULL(ОстаткиПодразделенийОстатки.КоличествоОстаток, 0) КАК Разница,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ОстаткиПодразделенийОстатки.КоличествоОстаток, 0) = 0
	|			ТОГДА 0
	|		ИНАЧЕ ОстаткиПодразделенийОстатки.СуммаОстаток / ОстаткиПодразделенийОстатки.КоличествоОстаток * ТаблицаДокумента.Количество
	|	КОНЕЦ КАК Себестоимость,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.Количество > ЕСТЬNULL(ОстаткиПодразделенийОстатки.КоличествоОстаток, 0)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ТовараНедостаточно
	|ИЗ
	|	ТаблицаДокумента КАК ТаблицаДокумента
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиПодразделений.Остатки(&ГраницаДокумента, ) КАК ОстаткиПодразделенийОстатки
	|		ПО ТаблицаДокумента.Канцтовар = ОстаткиПодразделенийОстатки.Канцтовар
	|			И ТаблицаДокумента.Подразделение = ОстаткиПодразделенийОстатки.Подразделение");
	
	
	Движения.ОстаткиПодразделений.Записывать = Истина;
	
Запрос.УстановитьПараметр("Ссылка", Ссылка);

Если ЭтоНовый() Тогда
    Запрос.УстановитьПараметр("ГраницаДокумента", Новый Граница(ТекущаяДата(), ВидГраницы.Исключая));
Иначе
    Запрос.УстановитьПараметр("ГраницаДокумента", Новый Граница(МоментВремени(), ВидГраницы.Исключая));
КонецЕсли;
Выборка = Запрос.Выполнить().Выбрать();
Пока Выборка.Следующий() Цикл
		Если Выборка.ТовараНедостаточно Тогда
			Отказ = Истина;
			Сообщить("По канцтовару " + Выборка.Канцтовар + "Недостаточно остатка по регистру Остатки подразделений! Не хватает " + Выборка.Разница + "шт");
		КонецЕсли;
		Движение = Движения.ОстаткиПодразделений.Добавить();
		Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
		Движение.Период = Дата;
		Движение.Канцтовар = Выборка.Канцтовар;
		Движение.Подразделение = Выборка.Подразделение;
		Движение.Количество = Выборка.Количество;
		Движение.Сумма = Выборка.Себестоимость;
		Движение.Комментарий = Комментарий;
		КонецЦикла;
 
	Движения.ЗатратыНаКанцтовары.Записывать = Истина;
	Для Каждого ТекСтрокаЗаявки Из Заявки Цикл
		Движение = Движения.ЗатратыНаКанцтовары.Добавить();
		Движение.Период = Дата;
		Движение.Канцтовар = ТекСтрокаЗаявки.Канцтовар;
		Движение.Сотрудник = ТекСтрокаЗаявки.Сотрудник;
		Движение.Подразделение = ТекСтрокаЗаявки.Подразделение;
		Движение.ДокументЗатрат = ТекСтрокаЗаявки.ЗаявкаСотрудника;
		Движение.Количество = ТекСтрокаЗаявки.Количество;
		Движение.Сумма = 10;
		Движение.Комментарий = Комментарий;
	КонецЦикла;

	Движения.Себестоимость.Записывать = Истина;
	Для Каждого ТекСтрокаЗаявки Из Заявки Цикл
		Движение = Движения.Себестоимость.Добавить();
		Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
		Движение.Период = Дата;
		Движение.Канцтовар = ТекСтрокаЗаявки.Канцтовар;
		Движение.Количество = ТекСтрокаЗаявки.Количество;
		Движение.Сумма = 10;
		Движение.Комментарий = Комментарий;
	КонецЦикла;

КонецПроцедуры
